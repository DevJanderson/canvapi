{
  "name": "@canvapi/core",
  "version": "0.1.0",
  "description": "OpenAPI renderer with canvas visualization",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": {
      "development": "./src/style.css",
      "default": "./dist/style.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue-flow/core": "^1.41.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
