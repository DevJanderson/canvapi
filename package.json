{
  "name": "canvapi",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "API documentation with canvas visualization — drop-in replacement for Swagger UI and Scalar",
  "author": "DevJanderson",
  "license": "MIT",
  "keywords": ["openapi", "api-documentation", "canvas", "swagger", "scalar", "vue"],
  "repository": {
