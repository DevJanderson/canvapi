    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "prettier": "^3.4.0",
    "typescript-eslint": "^8.20.0",
    "vue-eslint-parser": "^10.0.0"
  }
